font-size = 16

theme = Vague 
unfocused-split-opacity = 0.4
split-divider-color = #ccbbaa

keybind = global:cmd+;=toggle_quick_terminal
keybind = global:cmd+i=prompt_surface_title
quick-terminal-position = bottom
quick-terminal-autohide = true
quick-terminal-size = 50%

keybind = cmd+alt+enter=toggle_split_zoom
keybind = cmd+alt+h=goto_split:left
keybind = cmd+alt+j=goto_split:bottom
keybind = cmd+alt+k=goto_split:top
keybind = cmd+alt+l=goto_split:right

macos-option-as-alt = left

window-padding-y = 0
window-padding-color = "extend"
window-padding-balance = true
title = " "
macos-titlebar-proxy-icon = hidden
window-save-state = never
